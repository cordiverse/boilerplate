{
  "name": "@cordiverse/boilerplate",
  "version": "0.4.0",
  "private": true,
  "files": [
    ".env",
    "cordis.yml"
  ],
  "license": "MIT",
  "workspaces": [
    "external/*",
    "external/*/external/*",
    "external/*/external/*/packages/*",
    "external/*/packages/*",
    "packages/*"
  ],
  "scripts": {
    "build": "yakumo build",
    "dev": "cross-env NODE_ENV=development cordis run --import tsx --import yml-register",
    "start": "cordis run"
  },
  "devDependencies": {
    "@cordisjs/client": "^0.4.0",
    "@types/node": "^25.3.5",
    "cross-env": "^10.1.0",
    "esbuild": "^0.28.0",
    "tsx": "npm:@cordiverse/tsx@4.19.3-fix.3",
    "typescript": "^5.9.3",
    "yakumo": "^3.1.0",
    "yakumo-esbuild": "^3.0.1",
    "yakumo-tsc": "^3.0.1",
    "yml-register": "^1.2.5"
  },
  "dependencies": {
    "@cordisjs/plugin-cli": "^1.1.0",
    "@cordisjs/plugin-cli-cordis": "^1.0.3",
    "@cordisjs/plugin-env": "^1.0.1",
    "@cordisjs/plugin-group": "^1.0.0",
    "@cordisjs/plugin-hmr": "^1.0.10",
    "@cordisjs/plugin-http": "^1.3.0",
    "@cordisjs/plugin-http-socks": "^1.0.0",
    "@cordisjs/plugin-include": "^1.0.2",
    "@cordisjs/plugin-insight": "^4.1.0",
    "@cordisjs/plugin-loader-webui": "^0.6.0",
    "@cordisjs/plugin-logger-webui": "^0.2.0",
    "@cordisjs/plugin-notifier": "^0.4.0",
    "@cordisjs/plugin-server": "^1.3.0",
    "@cordisjs/plugin-timer": "^1.1.1",
    "@cordisjs/plugin-webui": "^0.4.0",
    "cordis": "^4.0.0-rc.2"
  }
}
